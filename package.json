{
  "name": "citation-generator-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "cf:dry-run": "wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "download:csl": "node scripts/download-csl.mjs",
    "sync:nlm": "node scripts/sync-nlm.mjs",
    "csl:clone": "git clone https://github.com/citation-style-language/styles.git data/csl/all-styles",
    "csl:manifest": "node scripts/build-csl-manifest.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.3.2",
    "cheerio": "^1.2.0",
    "citeproc": "^2.4.63",
    "clsx": "^2.1.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "better-sqlite3": "^12.11.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
